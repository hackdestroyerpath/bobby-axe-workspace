{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "TRADING_ALGOS/BEN_KIM_SYMBOL_OBJECT_SCHEMA.json",
  "title": "Ben_Kim Symbol Object",
  "description": "Phase 3 packaging contract for one symbol-scoped machine response and its storage-ready envelope.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "symbol",
    "strategy",
    "timeframe",
    "machine_id",
    "agent_id",
    "request_id",
    "requested_at",
    "generated_at",
    "source",
    "status",
    "object_readiness",
    "response_contract_version",
    "input_window",
    "summary",
    "meta",
    "features",
    "errors",
    "packaging_issues"
  ],
  "properties": {
    "symbol": {"type": "string", "minLength": 1},
    "strategy": {
      "type": "string",
      "enum": ["RSI_MACD", "LEVELS_FIBO_HV", "VOLUME", "ELLIOTT"]
    },
    "timeframe": {
      "type": "string",
      "enum": ["1m", "5m", "60m"]
    },
    "machine_id": {"type": "string", "minLength": 1},
    "agent_id": {"type": "string", "minLength": 1},
    "request_id": {"type": "string", "minLength": 1},
    "requested_at": {"type": "string", "format": "date-time"},
    "generated_at": {"type": "string", "format": "date-time"},
    "source": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["ready", "partial", "error"]
    },
    "object_readiness": {
      "type": "string",
      "enum": ["ready", "partial", "blocked"]
    },
    "response_contract_version": {"type": "string", "minLength": 1},
    "input_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": {"type": "string", "format": "date-time"},
        "to": {"type": "string", "format": "date-time"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "strength", "confidence", "note"],
      "properties": {
        "state": {"type": "string"},
        "strength": {"type": "string"},
        "confidence": {"type": "string"},
        "note": {"type": "string"}
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "data_points",
        "is_partial",
        "coverage_ratio",
        "source_contract_version",
        "build_version",
        "api_key_id",
        "machine_id"
      ],
      "properties": {
        "data_points": {"type": "integer", "minimum": 0},
        "is_partial": {"type": "boolean"},
        "partial_reason": {"type": ["string", "null"]},
        "coverage_ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "source_contract_version": {"type": "string", "minLength": 1},
        "build_version": {"type": "string", "minLength": 1},
        "api_key_id": {"type": "string", "minLength": 1},
        "machine_id": {"type": "string", "minLength": 1}
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": true
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message", "severity", "scope", "retryable"],
        "properties": {
          "code": {"type": "string", "minLength": 1},
          "message": {"type": "string", "minLength": 1},
          "severity": {"type": "string", "minLength": 1},
          "scope": {"type": "string", "minLength": 1},
          "retryable": {"type": "boolean"}
        }
      }
    },
    "packaging_issues": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
