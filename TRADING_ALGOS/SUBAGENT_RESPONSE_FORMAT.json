{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "TRADING_ALGOS/SUBAGENT_RESPONSE_FORMAT.json",
  "title": "Trading Subagent Response",
  "description": "Unified response contract for all 12 trading strategy machines.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "strategy",
    "timeframe",
    "symbol",
    "source",
    "requested_at",
    "as_of",
    "response_contract_version",
    "status",
    "input_window",
    "features",
    "summary",
    "meta",
    "errors"
  ],
  "properties": {
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "strategy": {
      "type": "string",
      "enum": [
        "RSI_MACD",
        "LEVELS_FIBO_HV",
        "VOLUME",
        "ELLIOTT"
      ]
    },
    "timeframe": {
      "type": "string",
      "enum": [
        "1m",
        "5m",
        "60m"
      ]
    },
    "symbol": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "as_of": {
      "type": "string",
      "format": "date-time"
    },
    "response_contract_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "partial",
        "error"
      ]
    },
    "input_window": {
      "$ref": "#/$defs/inputWindow"
    },
    "features": {
      "type": "object",
      "description": "Strategy-specific computed features payload.",
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "strength",
        "confidence",
        "note"
      ],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "bullish",
            "bearish",
            "neutral",
            "mixed",
            "unclear"
          ]
        },
        "strength": {
          "type": "string",
          "enum": [
            "weak",
            "medium",
            "strong"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/error"
      }
    }
  },
  "$defs": {
    "inputWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "type": "string",
          "format": "date-time"
        },
        "to": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "data_points",
        "is_partial",
        "coverage_ratio",
        "source_contract_version",
        "build_version",
        "api_key_id",
        "machine_id"
      ],
      "properties": {
        "data_points": {
          "type": "integer",
          "minimum": 0
        },
        "is_partial": {
          "type": "boolean"
        },
        "partial_reason": {
          "type": [
            "string",
            "null"
          ],
          "description": "Short machine-readable reason when partial output is returned."
        },
        "coverage_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source_contract_version": {
          "type": "string",
          "minLength": 1
        },
        "build_version": {
          "type": "string",
          "minLength": 1
        },
        "api_key_id": {
          "type": "string",
          "minLength": 1
        },
        "machine_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "severity",
        "scope",
        "retryable"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "warning",
            "error"
          ]
        },
        "scope": {
          "type": "string",
          "enum": [
            "input",
            "read",
            "normalization",
            "features",
            "output",
            "transport"
          ]
        },
        "retryable": {
          "type": "boolean"
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "partial"
          }
        }
      },
      "then": {
        "properties": {
          "meta": {
            "properties": {
              "is_partial": {
                "const": true
              },
              "partial_reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "partial_reason"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "meta": {
            "properties": {
              "is_partial": {
                "const": true
              }
            },
            "required": [
              "is_partial"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "status": {
            "const": "partial"
          },
          "meta": {
            "properties": {
              "partial_reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "partial_reason"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "ready"
          }
        }
      },
      "then": {
        "properties": {
          "meta": {
            "properties": {
              "is_partial": {
                "const": false
              },
              "partial_reason": {
                "enum": [
                  null
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "error"
          }
        }
      },
      "then": {
        "properties": {
          "errors": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
