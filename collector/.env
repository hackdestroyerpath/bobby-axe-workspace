# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/data_collector

# Binance
BINANCE_REST_BASE_URL=https://fapi.binance.com
BINANCE_WS_BASE_URL=wss://fstream.binance.com
BINANCE_SYMBOLS=1000BONKUSDC,1000PEPEUSDC,1000SHIBUSDC,AAVEUSDC,ADAUSDC,ARBUSDC,AVAXUSDC,BCHUSDC,BIOUSDC,BNBUSDC,BOMEUSDC,BTCUSDC,CRVUSDC,DOGEUSDC,ENAUSDC,ETHFIUSDC,ETHUSDC,FILUSDC,HBARUSDC
BINANCE_BACKFILL_DAYS=3

# Runtime
LOG_LEVEL=INFO
RECONCILE_LOOKBACK_MINUTES=5
