{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://antares.local/maffi/contract_v1.json",
  "title": "Maffi Contract v1 (traceability blocks)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "validation_summary",
    "decision_summary",
    "decision_trace"
  ],
  "properties": {
    "validation_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "counts",
        "errors",
        "warnings",
        "degrade",
        "top_reasons"
      ],
      "properties": {
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "total_checks",
            "passed",
            "failed",
            "warnings"
          ],
          "properties": {
            "total_checks": {"type": "integer", "minimum": 0},
            "passed": {"type": "integer", "minimum": 0},
            "failed": {"type": "integer", "minimum": 0},
            "warnings": {"type": "integer", "minimum": 0},
            "skipped": {"type": "integer", "minimum": 0}
          }
        },
        "errors": {
          "type": "array",
          "items": {"type": "string"}
        },
        "warnings": {
          "type": "array",
          "items": {"type": "string"}
        },
        "degrade": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "is_degraded",
            "degrade_score"
          ],
          "properties": {
            "is_degraded": {"type": "boolean"},
            "degrade_score": {"type": "number", "minimum": 0, "maximum": 1},
            "sources": {
              "type": "array",
              "items": {"type": "string"}
            },
            "policy": {"type": "string"}
          }
        },
        "top_reasons": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "count"],
            "properties": {
              "code": {"type": "string"},
              "count": {"type": "integer", "minimum": 1},
              "severity": {
                "type": "string",
                "enum": ["error", "warning", "degrade", "info"]
              }
            }
          }
        }
      }
    },
    "decision_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "direction",
        "selected_candidate_id",
        "tp_sl_logic_digest"
      ],
      "properties": {
        "direction": {
          "type": "string",
          "enum": ["long", "short", "reject"]
        },
        "selected_candidate_id": {"type": "string", "minLength": 1},
        "tp_sl_logic_digest": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "tp_basis", "sl_basis", "rr_estimate"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["atr_buffered", "structure_based", "mixed", "none"]
            },
            "tp_basis": {"type": "string", "minLength": 1},
            "sl_basis": {"type": "string", "minLength": 1},
            "rr_estimate": {"type": "number", "minimum": 0},
            "constraints": {
              "type": "array",
              "items": {"type": "string"}
            },
            "rejected_by": {"type": "string"},
            "notes": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      }
    },
    "decision_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "prefixItems": [
            {"$ref": "#/$defs/gateStep"},
            {"$ref": "#/$defs/directionStep"},
            {"$ref": "#/$defs/rangeStep"},
            {"$ref": "#/$defs/gridCountStep"},
            {"$ref": "#/$defs/tpSlStep"},
            {"$ref": "#/$defs/confidenceStep"}
          ],
          "items": false
        }
      }
    }
  },
  "$defs": {
    "stepBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "reason"],
      "properties": {
        "name": {"type": "string"},
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "skip"]
        },
        "reason": {"type": "string", "minLength": 1},
        "inputs": {"type": "object"},
        "outputs": {"type": "object"},
        "metrics": {"type": "object"},
        "warnings": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "gateStep": {
      "allOf": [
        {"$ref": "#/$defs/stepBase"},
        {"properties": {"name": {"const": "gate"}}}
      ]
    },
    "directionStep": {
      "allOf": [
        {"$ref": "#/$defs/stepBase"},
        {"properties": {"name": {"const": "direction"}}}
      ]
    },
    "rangeStep": {
      "allOf": [
        {"$ref": "#/$defs/stepBase"},
        {"properties": {"name": {"const": "range"}}}
      ]
    },
    "gridCountStep": {
      "allOf": [
        {"$ref": "#/$defs/stepBase"},
        {"properties": {"name": {"const": "grid_count"}}}
      ]
    },
    "tpSlStep": {
      "allOf": [
        {"$ref": "#/$defs/stepBase"},
        {"properties": {"name": {"const": "tp_sl"}}}
      ]
    },
    "confidenceStep": {
      "allOf": [
        {"$ref": "#/$defs/stepBase"},
        {"properties": {"name": {"const": "confidence"}}}
      ]
    }
  }
}
