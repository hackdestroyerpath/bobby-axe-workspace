{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/schemas/second_bar.schema.json",
  "title": "second_bar",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_type",
    "source",
    "symbol",
    "ts_second_utc",
    "open",
    "high",
    "low",
    "close",
    "base_volume",
    "trade_count",
    "buy_volume",
    "sell_volume",
    "timeframes",
    "status"
  ],
  "properties": {
    "event_type": { "const": "second_bar" },
    "source": { "type": "string", "minLength": 1 },
    "symbol": { "type": "string", "pattern": "^[A-Z0-9_\\-]+$" },
    "ts_second_utc": { "type": "string", "format": "date-time" },
    "open": { "type": "number" },
    "high": { "type": "number" },
    "low": { "type": "number" },
    "close": { "type": "number" },
    "base_volume": { "type": "number", "minimum": 0 },
    "trade_count": { "type": "integer", "minimum": 0 },
    "buy_volume": { "type": "number", "minimum": 0 },
    "sell_volume": { "type": "number", "minimum": 0 },
    "status": { "type": "string", "enum": ["ready", "partial"] },
    "timeframes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["1m", "5m", "60m"],
      "properties": {
        "1m": { "$ref": "#/$defs/ohlc" },
        "5m": { "$ref": "#/$defs/ohlc" },
        "60m": { "$ref": "#/$defs/ohlc" }
      }
    }
  },
  "$defs": {
    "ohlc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["open", "high", "low", "close"],
      "properties": {
        "open": { "type": "number" },
        "high": { "type": "number" },
        "low": { "type": "number" },
        "close": { "type": "number" }
      }
    }
  }
}
