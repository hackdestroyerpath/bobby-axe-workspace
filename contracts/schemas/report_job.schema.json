{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "contracts/schemas/report_job.schema.json",
    "title": "report_job",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "event_type",
        "job_id",
        "correlation_id",
        "report_type",
        "requested_at",
        "generated_at_utc",
        "report_period",
        "symbols",
        "artifacts",
        "delivery",
        "status"
    ],
    "properties": {
        "event_type": {
            "const": "report_job"
        },
        "job_id": {
            "type": "string",
            "minLength": 1
        },
        "correlation_id": {
            "type": "string",
            "minLength": 1
        },
        "report_type": {
            "type": "string",
            "enum": [
                "live_snapshot",
                "periodic_report",
                "exception_report",
                "portfolio_allocation_report"
            ]
        },
        "requested_at": {
            "type": "string",
            "format": "date-time"
        },
        "generated_at_utc": {
            "type": "string",
            "format": "date-time"
        },
        "report_period": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "from",
                "to"
            ],
            "properties": {
                "from": {
                    "type": "string",
                    "format": "date-time"
                },
                "to": {
                    "type": "string",
                    "format": "date-time"
                }
            }
        },
        "symbols": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "string",
                "pattern": "^[A-Z0-9_\\-]+$"
            },
            "uniqueItems": true
        },
        "artifacts": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "pdf_path",
                "table_path",
                "summary_path",
                "manifest_path"
            ],
            "properties": {
                "pdf_path": {
                    "type": "string",
                    "minLength": 1
                },
                "table_path": {
                    "type": "string",
                    "minLength": 1
                },
                "summary_path": {
                    "type": "string",
                    "minLength": 1
                },
                "manifest_path": {
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "delivery": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "channel"
            ],
            "properties": {
                "channel": {
                    "type": "string",
                    "enum": [
                        "user_download",
                        "email",
                        "telegram",
                        "internal_queue"
                    ]
                },
                "recipient": {
                    "type": "string"
                }
            }
        },
        "status": {
            "type": "string",
            "enum": [
                "queued",
                "running",
                "ready",
                "rejected",
                "error"
            ]
        },
        "pipeline_status": {
            "type": "string",
            "enum": [
                "ready",
                "partial",
                "blocked"
            ]
        },
        "decision": {
            "type": "string",
            "enum": [
                "publish",
                "informational_only",
                "revision_required",
                "escalate"
            ]
        }
    }
}
