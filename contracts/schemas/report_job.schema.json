{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/schemas/report_job.schema.json",
  "title": "report_job",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_type",
    "job_id",
    "requested_at",
    "report_period",
    "symbols",
    "artifacts",
    "delivery",
    "status"
  ],
  "properties": {
    "event_type": { "const": "report_job" },
    "job_id": { "type": "string", "minLength": 1 },
    "requested_at": { "type": "string", "format": "date-time" },
    "report_period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "format": "date-time" },
        "to": { "type": "string", "format": "date-time" }
      }
    },
    "symbols": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[A-Z0-9_\\-]+$" },
      "uniqueItems": true
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pdf_path"],
      "properties": {
        "pdf_path": { "type": "string", "minLength": 1 },
        "table_path": { "type": "string", "minLength": 1 }
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel"],
      "properties": {
        "channel": { "type": "string", "enum": ["user_download", "email", "telegram", "internal_queue"] },
        "recipient": { "type": "string" }
      }
    },
    "status": { "type": "string", "enum": ["queued", "running", "completed", "failed"] }
  }
}
