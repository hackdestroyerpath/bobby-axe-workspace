{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/schemas/analysis_result.schema.json",
  "title": "analysis_result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_type",
    "analysis_id",
    "symbol",
    "strategy",
    "frame",
    "signal",
    "conclusion",
    "confidence",
    "observed_at",
    "source_window",
    "status",
    "result_code"
  ],
  "properties": {
    "event_type": { "const": "analysis_result" },
    "analysis_id": { "type": "string", "minLength": 1 },
    "symbol": { "type": "string", "pattern": "^[A-Z0-9_-]+$" },
    "strategy": { "type": "string", "minLength": 1 },
    "frame": { "type": "string", "enum": ["1m", "5m", "60m"] },
    "signal": { "type": "string", "enum": ["bullish", "bearish", "neutral", "ignore"] },
    "conclusion": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "observed_at": { "type": "string", "format": "date-time" },
    "source_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "format": "date-time" },
        "to": { "type": "string", "format": "date-time" }
      }
    },
    "status": { "type": "string", "enum": ["ready", "partial", "rejected"] },
    "result_code": { "type": "string", "enum": ["ok", "skipped", "insufficient_data", "error"] },
    "details": { "type": "object" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "result_code": { "const": "ok" } },
        "required": ["result_code"]
      },
      "then": {
        "properties": { "status": { "const": "ready" } }
      }
    },
    {
      "if": {
        "properties": { "result_code": { "enum": ["skipped", "insufficient_data"] } },
        "required": ["result_code"]
      },
      "then": {
        "properties": { "status": { "const": "partial" } }
      }
    },
    {
      "if": {
        "properties": { "result_code": { "const": "error" } },
        "required": ["result_code"]
      },
      "then": {
        "properties": { "status": { "const": "rejected" } }
      }
    }
  ]
}
