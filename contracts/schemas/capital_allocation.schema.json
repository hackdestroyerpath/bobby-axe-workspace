{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/schemas/capital_allocation.schema.json",
  "title": "capital_allocation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_type",
    "allocation_id",
    "symbol",
    "proposal_id",
    "allocation_pct",
    "risk_bucket",
    "rationale",
    "approved_at",
    "status"
  ],
  "properties": {
    "event_type": { "const": "capital_allocation" },
    "allocation_id": { "type": "string", "minLength": 1 },
    "symbol": { "type": "string", "pattern": "^[A-Z0-9_\\-]+$" },
    "proposal_id": { "type": "string", "minLength": 1 },
    "allocation_pct": { "type": "number", "minimum": 0, "maximum": 100 },
    "risk_bucket": { "type": "string", "enum": ["low", "medium", "high"] },
    "rationale": { "type": "string", "minLength": 1 },
    "approved_at": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["ready", "rejected"] },
    "supporting_analysis_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
